{
  "name": "pet-joyful-backend",
  "version": "1.1.1",
  "description": "Backend em microsserviços para o projeto Pet Joyful (Java + Node.js + Express)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch backend/src --watch server.ts --exec tsx ./server.ts",
    "build": "tsc --build",
    "postbuild": "copyfiles -u 2 backend/src/swagger-output.json dist/backend/src/config",
    "start": "node dist/server.js",
    "start:prod": "npm run build && npm start",
    "swagger": "tsx backend/src/swagger.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@google/genai": "^1.47.0",
    "@google/generative-ai": "^0.24.1",
    "@logtail/node": "^0.5.8",
    "@logtail/winston": "^0.5.8",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.19.1",
    "serverless-http": "^4.0.0",
    "swagger-autogen": "^2.23.7",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tsconfig/node24": "^24.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/http-proxy-middleware": "^0.19.3",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/winston": "^2.4.4",
    "copyfiles": "^2.4.1",
    "dotenv": "^17.4.2",
    "eslint": "^9.0.0",
    "eslint-plugin-perfectionist": "^4.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.2.5",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  }
}
